{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Async" ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "catalog_service": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            { "Name": "Console" },
            {
              "Name": "File",
              "Args": {
                "path": "Logs/log-.txt",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 30,
                "fileSizeLimitBytes": 10485760,
                "rollOnFileSizeLimit": true,
                "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
              }
            }
          ]
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "catalog_service": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Key": "REPLACE_WITH_ENV_VAR_JWT_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "catalog-service",
    "Audience": "catalog-service-clients"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "Redis": {
    "RestUrl": "",
    "RestToken": "",
    "InstanceName": "catalog-service:",
    "CacheTtlSeconds": {
      "GetAll": 60,
      "GetById": 120
    }
  },
  "Firebase": {
    "ServiceAccountKeyPath": "firebase-service-account.json",
    "ProjectId": "your-firebase-project-id",
    "WebApiKey": "your-firebase-web-api-key",
    "ActionCodeSettings": {
      "Url": "https://billflow.page.link/login",
      "HandleCodeInApp": true,
      "AndroidPackageName": "com.techmindrsg.billflow",
      "AndroidInstallApp": true,
      "AndroidMinimumVersion": "21",
      "IosBundleId": "com.techmindrsg.billflow"
    }
  },
  "Email": {
    "Provider": "SendGrid",
    "ApiKey": "",
    "FromAddress": "noreply@billflow.com",
    "FromName": "BillFlow"
  }
}
